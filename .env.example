# Copy to .env.local and replace with values from Firebase Console → Project settings → Your apps (Web).
# Email/password: Authentication → Sign-in method → enable Email/Password.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
